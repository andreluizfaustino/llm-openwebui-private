# This file is managed by the setup wizard — do not edit manually.
# Copy to open-webui.env before first run (docker compose up will use it).
# The setup wizard will overwrite this file with your chosen settings.
#
# ENABLE_PERSISTENT_CONFIG=false forces Open WebUI to always read from
# env vars, overriding values previously persisted in the database.
ENABLE_PERSISTENT_CONFIG=false
WEBUI_AUTH=true
ENABLE_SIGNUP=false
DEFAULT_USER_ROLE=pending
ENABLE_LOGIN_FORM=true
WEBUI_SECRET_KEY=changeme-will-be-replaced-by-setup-wizard
OLLAMA_BASE_URL=http://ollama:11434
